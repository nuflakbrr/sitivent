generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  name               String?
  emailVerified      Boolean          @default(false) @map("email_verified")
  image              String?
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  role               String?
  banned             Boolean?         @default(false)
  banReason          String?          @map("ban_reason")
  banExpires         DateTime?        @map("ban_expires")
  roleId             String?          @map("role_id")
  accounts           Account[]
  articles           Article[]
  scannedAttendances Attendance[]     @relation("ScannerToAttendance")
  auditLogs          AuditLog[]
  certificates       Certificate[]
  events             Event[]
  verifiedPayments   Payment[]
  registrations      Registration[]
  sessions           Session[]
  supportMessages    SupportMessage[]
  testimonials       Testimonial[]

  roles              Role[]           @relation("RoleToUser")

  @@map("users")
}

model Session {
  id             String   @id @default(uuid())
  expiresAt      DateTime @map("expires_at")
  token          String   @unique
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  userId         String   @map("user_id")
  impersonatedBy String?  @map("impersonated_by")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

model Permission {
  id                    String                @id @default(uuid())
  name                  String                @unique
  description           String?
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")
  model_has_permissions ModelHasPermissions[]
  role_has_permissions  RoleHasPermission[]
  roles                 Role[]                @relation("PermissionToRole")

  @@map("permissions")
}

model Role {
  id                  String                @id @default(uuid())
  name                String                @unique
  description         String?
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  modelHasPermissions ModelHasPermissions[]
  roleHasPermissions  RoleHasPermission[]
  permissions         Permission[]          @relation("PermissionToRole")
  users               User[]                @relation("RoleToUser")

  @@map("roles")
}

model RoleHasPermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  permissions  Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_has_permissions")
}

model ModelHasPermissions {
  modelId      String     @map("model_id")
  modelType    String     @map("model_type")
  permissionId String     @map("permission_id")
  roleId       String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  permissions  Permission @relation(fields: [permissionId], references: [id])
  role         Role?      @relation(fields: [roleId], references: [id])

  @@id([modelId, modelType, permissionId])
  @@map("model_has_permissions")
}

model EventCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  events      Event[]

  @@map("event_categories")
}

model Event {
  id                   String               @id @default(cuid())
  title                String
  slug                 String               @unique
  description          String
  banner               String?
  startDate            DateTime             @map("start_date")
  endDate              DateTime             @map("end_date")
  startTime            String               @map("start_time")
  endTime              String               @map("end_time")
  location             String
  eventType            EventType            @map("event_type")
  onlineAttendance     Boolean              @default(false) @map("online_attendance")
  registrationDeadline DateTime             @map("registration_deadline")
  quota                Int
  price                Int
  status               EventStatus          @default(DRAFT)
  certificateEnabled   Boolean              @default(false) @map("certificate_enabled")
  publishedAt          DateTime?            @map("published_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  deletedAt            DateTime?            @map("deleted_at")
  categoryId           String?              @map("category_id")
  meetingLink          String?              @map("meeting_link")
  createdById          String?              @map("created_by_id")
  certificateTemplate  CertificateTemplate?
  certificates         Certificate[]
  benefits             EventBenefit[]
  speakers             EventSpeaker[]
  category             EventCategory?       @relation(fields: [categoryId], references: [id])
  createdBy            User?                @relation(fields: [createdById], references: [id])
  galleries            Gallery[]
  registrations        Registration[]
  testimonials         Testimonial[]

  @@map("events")
}

model Registration {
  id                 String             @id @default(cuid())
  eventId            String             @map("event_id")
  userId             String             @map("user_id")
  registrationNumber String             @unique @map("registration_number")
  qrToken            String?            @unique @map("qr_token")
  onlineAttendance   Boolean            @default(false) @map("online_attendance")
  status             RegistrationStatus @default(WAITING_PAYMENT)
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  deletedAt          DateTime?          @map("deleted_at")
  attendances        Attendance[]
  certificates       Certificate[]
  payment            Payment?
  testimonial        Testimonial?
  event              Event              @relation(fields: [eventId], references: [id])
  user               User               @relation(fields: [userId], references: [id])

  @@map("registrations")
}

model Payment {
  id             String        @id @default(cuid())
  registrationId String        @unique @map("registration_id")
  amount         Int
  status         PaymentStatus @default(WAITING)
  proofUrl       String?       @map("proof_url")
  verifiedAt     DateTime?     @map("verified_at")
  verifiedById   String?       @map("verified_by_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")
  registration   Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  verifiedBy     User?         @relation(fields: [verifiedById], references: [id])

  @@map("payments")
}

model CertificateTemplate {
  id                 String                 @id @default(cuid())
  eventId            String                 @unique @map("event_id")
  backgroundUrl      String?                @map("background_url")
  numberTemplate     String                 @default("CERT/{SLUG}/{REG_NO}") @map("number_template")
  numberMode         CertNumberMode         @default(AUTO) @map("number_mode")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  contentColor       String?                @map("content_color")
  contentFont        String?                @map("content_font")
  footerMarginBottom Int?                   @default(0) @map("footer_margin_bottom")
  headerColor        String?                @map("header_color")
  headerFont         String?                @map("header_font")
  headerSubtitle     String?                @default("Sertifikat Partisipasi Resmi") @map("header_subtitle")
  headerText         String?                @default("SITIVENT") @map("header_text")
  primaryColor       String?                @map("primary_color")
  showEventDate      Boolean?               @default(true) @map("show_event_date")
  showEventLocation  Boolean?               @default(false) @map("show_event_location")
  showHeader         Boolean?               @default(true) @map("show_header")
  showIssuedDate     Boolean                @default(true) @map("show_issued_date")
  titleColor         String?                @map("title_color")
  titleFont          String?                @map("title_font")
  signatures         CertificateSignature[]
  event              Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("certificate_templates")
}

model CertificateSignature {
  id           String              @id @default(cuid())
  templateId   String              @map("template_id")
  name         String
  title        String?
  signatureUrl String              @map("signature_url")
  order        Int                 @default(0)
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  template     CertificateTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("certificate_signatures")
}

model Certificate {
  id                String       @id @default(cuid())
  registrationId    String       @map("registration_id")
  eventId           String       @map("event_id")
  userId            String       @map("user_id")
  certificateNumber String       @unique @map("certificate_number")
  templateUrl       String?      @map("template_url")
  pdfUrl            String       @map("pdf_url")
  downloadUrl       String       @map("download_url")
  downloadTime      DateTime?    @map("download_time")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  event             Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration      Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

model Attendance {
  id             String           @id @default(cuid())
  registrationId String?          @map("registration_id")
  scanTime       DateTime         @default(now()) @map("scan_time")
  scannerId      String?          @map("scanner_id")
  status         AttendanceStatus
  registration   Registration?    @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  scanner        User?            @relation("ScannerToAttendance", fields: [scannerId], references: [id])

  @@map("attendances")
}

model Testimonial {
  id             String       @id @default(cuid())
  registrationId String       @unique @map("registration_id")
  eventId        String       @map("event_id")
  userId         String       @map("user_id")
  rating         Int
  comment        String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("testimonials")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String
  table     String
  recordId  String   @map("record_id")
  oldValues String?  @map("old_values")
  newValues String?  @map("new_values")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model EmailQueue {
  id          String      @id @default(cuid())
  to          String
  subject     String
  body        String
  attachments String?
  status      EmailStatus @default(PENDING)
  attempts    Int         @default(0)
  error       String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("email_queues")
}

model SupportMessage {
  id         String   @id @default(cuid())
  email      String
  phone      String
  name       String
  title      String
  category   String
  chronology String   @map("chronology")
  status     String   @default("PENDING")
  userId     String?  @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User?    @relation(fields: [userId], references: [id])

  @@map("support_messages")
}

model Gallery {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String   @map("image_url")
  featured    Boolean  @default(false)
  eventId     String?  @map("event_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  event       Event?   @relation(fields: [eventId], references: [id])

  @@map("galleries")
}

model ArticleCategory {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  articles  Article[]

  @@map("article_categories")
}

model Article {
  id                String            @id @default(uuid())
  title             String
  content           String
  cover             String?
  createdAt         DateTime          @default(now()) @map("created_at")
  createdById       String?           @map("created_by_id")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  slug              String?           @unique
  articleCategories ArticleCategory[]
  createdBy         User?             @relation(fields: [createdById], references: [id])

  @@map("articles")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("newsletter_subscribers")
}

model EventBenefit {
  id          String   @id @default(cuid())
  eventId     String   @map("event_id")
  title       String
  description String?
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_benefits")
}

model EventSpeaker {
  id         String   @id @default(cuid())
  eventId    String   @map("event_id")
  name       String
  title      String?
  company    String?
  companyUrl String?  @map("company_url")
  github     String?
  instagram  String?
  linkedIn   String?
  avatar     String?
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_speakers")
}



enum EventType {
  ONLINE
  OFFLINE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CLOSED
  COMPLETED
}

enum RegistrationStatus {
  WAITING_PAYMENT
  REGISTERED
  CANCELLED
  CHECKED_IN
}

enum PaymentStatus {
  WAITING
  PAID
  FAILED
  REFUNDED
}

enum CertNumberMode {
  AUTO
  MANUAL
}

enum AttendanceStatus {
  SUCCESS
  FAILED
}

enum EmailStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}
